MONGO_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_here
PORT=5000

# ── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Resend (email service) ─────────────────────────────────
# Get your free key at https://resend.com → API Keys
RESEND_API_KEY=your_resend_api_key
# Sender — use 'onboarding@resend.dev' for testing OR your verified domain
RESEND_FROM=Your App Name <your@email.com>
# Admin email that receives contact form + application notifications
ADMIN_EMAIL=your@email.com

# ── Google OAuth ───────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── App URLs ───────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# ── Session secret (for Passport.js) ──────────────────────
SESSION_SECRET=your_session_secret_here
